{
  "name": "UrbanBites Admin",
  "version": "1.0",
  "manifest_version": 3,
  "description": "Extensie pentru administrarea restaurantului UrbanBites",
  "action": {
    "default_popup": "index.html",
    "default_icon": "assets/icons/icon-128.png"
  },
  "icons": {
    "128": "assets/icons/icon-128.png"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "http://localhost:8080/*"
  ]
}